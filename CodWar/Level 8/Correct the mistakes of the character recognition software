#include <string>
using namespace std;


std::string correct(std::string str){
  string res = "";
  for(int i = 0; i < str.length(); i++)
  {
    if(str[i] == '5')
      res += 'S';
    else if(str[i] == '0')
      res += 'O';
    else if(str[i] == '1')
      res += 'I';
    else
      res += str[i];
  }
  return res;
  //your code here
}
