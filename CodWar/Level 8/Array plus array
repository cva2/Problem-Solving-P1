#include <vector>
#include <string>
using namespace std;

int arrayPlusArray(std::vector<int> a, std::vector<int> b) {
  
  int res = 0;
  
    for (int i = 0; i < a.size(); i++) 
    {
        res += a[i];
    }

    // Add all elements of second array
    for (int i = 0; i < b.size(); i++) 
    {
        res += b[i];
    }
  
  return res; 
}
